# SignFlow Environment Variables
# Copy this file to .env on your server and fill in real values.
# NEVER commit .env to git.

# ── Auth0 (required) ─────────────────────────────────────────────────────────
# Your Auth0 tenant domain (no https://)
AUTH0_DOMAIN=dev-xxxxxxxx.us.auth0.com

# Application credentials from Auth0 Dashboard → Applications → Your App
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here

# Must match exactly what you set in Auth0 → Allowed Callback URLs
AUTH0_CALLBACK_URL=https://yourdomain.com/auth/callback

# The Auth0 role name that grants admin access (create this in Auth0 → Roles)
AUTH0_ADMIN_ROLE=signflow-admin

# Random string for signing session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# ── hCaptcha (optional) ───────────────────────────────────────────────────────
# Only needed if CAPTCHA is enabled in admin Settings
SF_HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
